generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Key {
  id            String     @id @default(uuid()) @db.Uuid
  platform      String
  name          String
  secret_key    String
  key_preview   String?
  status        String     @default("active")
  last_used_at  DateTime   @default(dbgenerated("'1970-01-01 00:00:00+00'::timestamp with time zone"))
  cooling_until DateTime?
  last_error    String?
  fail_count    Int        @default(0)
  created_at    DateTime   @default(now())
  usage_logs    UsageLog[]

  @@index([last_used_at])
  @@index([created_at])
  @@map("keys")
}

model UsageLog {
  id             String   @id @default(uuid()) @db.Uuid
  key_id         String   @db.Uuid
  project_name   String
  request_status String
  error_message  String?
  created_at     DateTime @default(now())
  key            Key      @relation(fields: [key_id], references: [id], onDelete: Cascade)

  @@index([key_id])
  @@map("usage_logs")
}
