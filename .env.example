# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://keyrelay:your_password@localhost:5432/keyrelay?schema=public"
KEYRELAY_ENCRYPTION_SECRET="replace-with-a-long-random-secret"
KEYRELAY_EXTERNAL_API_TOKEN="replace-with-your-external-api-token"
CALLBACK_SECRET="replace-with-callback-shared-secret"
CALLBACK_DEFAULT_PROJECT_NAME="gemini-callback"

# Database reset protection (production-safe)
# Set to true only when you intentionally need to reset runtime data.
KEYRELAY_ALLOW_DATABASE_RESET="false"
KEYRELAY_DATABASE_RESET_TOKEN="replace-with-a-different-high-entropy-token"
