# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://keyrelay:your_password@localhost:5432/keyrelay?schema=public"
KEYRELAY_ENCRYPTION_SECRET="replace-with-a-long-random-secret"
KEYRELAY_EXTERNAL_API_TOKEN="replace-with-your-external-api-token"
